# ======= LLM API 配置 ========
# 支持 OpenAI / DeepSeek 等兼容 API
OPENAI_API_KEY=sk-518b52a6d9fb4d94bc309b1c6262b8a5
OPENAI_API_BASE=https://api.deepseek.com/v1

# ======= 数据库配置 ==========
# 支持多种数据库类型：
#   PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/dbname
#   MySQL:      mysql+pymysql://user:password@localhost:3306/dbname
#   SQLite:     sqlite:///path/to/database.db
#   DuckDB:     duckdb:///path/to/database.duckdb
AGENT_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/demo

# ======= 飞书群通知配置 =======
# 获取方式: 飞书电脑端 → 打开目标群 → 设置(右上角) → 群机器人 → 添加机器人 → 自定义机器人
#          → 复制 Webhook 地址粘贴到下方（注意保密，不要泄露）
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/ded13f2d-fd0a-4417-b9dd-7d12a941858f
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/9b9470e2-88b0-4afd-a975-92d8839bd0bc
FEISHU_APP_ID=cli_a923fc1649f89bb6
FEISHU_APP_SECRET=AeKhprlD4siLB1SfAbN3hePblQYt6mP2

# ======= 邮件发送配置 (SMTP) =======
# QQ 邮箱: SMTP_SERVER=smtp.qq.com, SMTP_PORT=465
# 网易邮箱: SMTP_SERVER=smtp.163.com, SMTP_PORT=465
# Gmail:   SMTP_SERVER=smtp.gmail.com, SMTP_PORT=465
# 注意: 需使用"授权码"而非登录密码（QQ邮箱: 设置→账户→POP3/SMTP→生成授权码）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code


# ======= RAG模型配置 =======
# RAG配置来源：env / db / auto
# env: 完全由 .env 控制；db: 前端RAG设置可写入数据库；auto: 优先使用数据库配置，不存在时回退 .env
RAG_CONFIG_SOURCE=env
# 是否开启每轮对话的RAG注入
ENABLE_PROMPT_RAG_CONTEXT=true
# 使用本地已下载模型路径（避免运行时再联网下载）
EMBEDDING_MODEL_NAME=C:/Dev/my-sql-agent-trae/models/huggingface/BAAI/bge-m3
# true: 仅本地模型，不访问HF
EMBEDDING_LOCAL_ONLY=true
# 检索注入条数（1-8）
EMBEDDING_RETRIEVAL_K=3
# 模型缓存目录（放在项目内）
EMBEDDING_CACHE_FOLDER=C:/Dev/my-sql-agent-trae/models/huggingface
# HF访问令牌（用于更高配额与稳定下载）
HF_TOKEN=
