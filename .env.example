# ======= LLM API 配置 ========
# 支持 OpenAI / DeepSeek 等兼容 API
OPENAI_API_KEY=sk-xxxxxxx
OPENAI_API_BASE=https://api.openai.com/v1

# ======= 数据库配置 ==========
# 支持多种数据库类型：
#   PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/dbname
#   MySQL:      mysql+pymysql://user:password@localhost:3306/dbname
#   SQLite:     sqlite:///path/to/database.db
#   DuckDB:     duckdb:///path/to/database.duckdb
AGENT_DATABASE_URL=

# ======= 飞书群通知配置 =======
# 获取方式: 飞书电脑端 → 打开目标群 → 设置(右上角) → 群机器人 → 添加机器人 → 自定义机器人
#          → 复制 Webhook 地址粘贴到下方（注意保密，不要泄露）
FEISHU_WEBHOOK_URL=

# （可选）飞书应用凭证 - 用于上传图表图片到飞书卡片
# 获取方式: https://open.feishu.cn → 开发者后台 → 创建企业自建应用 → 凭证与基础信息
# 注意: 需要给应用添加 "机器人" 能力，并在"权限管理"中开通 im:resource（上传图片）权限
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ======= 邮件发送配置 (SMTP) =======
# QQ 邮箱: SMTP_SERVER=smtp.qq.com, SMTP_PORT=465
# 网易邮箱: SMTP_SERVER=smtp.163.com, SMTP_PORT=465
# Gmail:   SMTP_SERVER=smtp.gmail.com, SMTP_PORT=465
# 注意: 需使用"授权码"而非登录密码（QQ邮箱: 设置→账户→POP3/SMTP→生成授权码）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code

# ======= Embedding / RAG 配置 =======
# RAG配置来源：env / db / auto
# env: 完全由 .env 控制，前端RAG配置只读；db: 前端可保存到 app_metadata.db；auto: 有DB配置时优先DB，否则使用.env
RAG_CONFIG_SOURCE=env
# 是否在每次对话时自动注入 RAG 检索上下文
ENABLE_PROMPT_RAG_CONTEXT=true
# Embedding 模型（可替换为 BAAI/bge-m3、BAAI/bge-large-zh-v1.5 等）
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# true 时仅使用本地缓存，不访问 HuggingFace Hub
EMBEDDING_LOCAL_ONLY=false
# 注入检索条数（1-8）
# 每轮检索注入片段数量，建议 3（精度/延迟较平衡）
EMBEDDING_RETRIEVAL_K=3
# 可选：指定 HuggingFace 缓存目录
EMBEDDING_CACHE_FOLDER=
# 可选：HuggingFace Token（设置后可提高下载稳定性和速率）
HF_TOKEN=
